{
  "name": "@pedrito/engram",
  "version": "5.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "engram": "dist/engram"
  },
  "scripts": {
    "build": "bun build src/main.ts --compile --outfile dist/engram",
    "build:dev": "bun build src/main.ts --outdir dist",
    "build:macos-arm64": "bun build src/main.ts --compile --target=bun-macos-arm64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/pedrito-engram-macos-arm64",
    "build:macos-x64": "bun build src/main.ts --compile --target=bun-macos-x64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/pedrito-engram-macos-x64",
    "build:linux-x64": "bun build src/main.ts --compile --target=bun-linux-x64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/pedrito-engram-linux-x64",
    "build:windows-x64": "bun build src/main.ts --compile --target=bun-windows-x64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/pedrito-engram-windows-x64.exe",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "dev": "bun run src/main.ts serve",
    "start": "dist/engram serve"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
