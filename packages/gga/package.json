{
  "name": "@pedrito/gga",
  "version": "5.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "gga": "dist/gga"
  },
  "scripts": {
    "build": "bun build src/main.ts --compile --outfile dist/gga",
    "build:dev": "bun build src/main.ts --outdir dist",
    "build:macos-arm64": "bun build src/main.ts --compile --target=bun-macos-arm64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/gga-macos-arm64",
    "build:macos-x64": "bun build src/main.ts --compile --target=bun-macos-x64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/gga-macos-x64",
    "build:linux-x64": "bun build src/main.ts --compile --target=bun-linux-x64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/gga-linux-x64",
    "build:windows-x64": "bun build src/main.ts --compile --target=bun-windows-x64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/gga-windows-x64.exe",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
