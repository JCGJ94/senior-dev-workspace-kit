{
  "name": "@pedrito/installer",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "pedrito": "dist/pedrito"
  },
  "scripts": {
    "build": "bun build src/cli.ts --compile --outfile dist/pedrito",
    "build:dev": "bun build src/cli.ts --outdir dist",
    "build:macos-arm64": "bun build src/cli.ts --compile --target=bun-macos-arm64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/pedrito-macos-arm64",
    "build:macos-x64": "bun build src/cli.ts --compile --target=bun-macos-x64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/pedrito-macos-x64",
    "build:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/pedrito-linux-x64",
    "build:windows-x64": "bun build src/cli.ts --compile --target=bun-windows-x64 --define \"PEDRITO_VERSION=$(node -p \"require('../../package.json').version\")\" --outfile dist/pedrito-windows-x64.exe",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.0.0",
    "typescript": "^5.4.0"
  }
}
