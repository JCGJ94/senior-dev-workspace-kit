#!/bin/bash

# ==============================================================================
# Agent CLI — AI Engineering Workspace Kit V3
# Pedrito: developer copilot. SDD + Engram + Context7 + MCP as first-class rules.
# ==============================================================================

set -e

KIT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND="${1:-}"
if [ $# -gt 0 ]; then
    shift
fi
FORWARD_ARGS=("$@")

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

show_help() {
    echo -e "${BLUE}"
    echo "       ___  ____"
    echo "      / _ \/  _/"
    echo "     / __ _/ /  "
    echo "    /_/ |_/___/ "
    echo "                "
    echo "   A G E N T   K I T"
    echo -e "${NC}"
    echo -e "${BLUE}🤖 Unified AI Engineering CLI (v3)${NC}"
    echo -e "The bridge between LLM reasoning and professional source code.\n"
    echo -e "Usage: ${GREEN}bash scripts/agent <command>${NC}\n"
    echo "Commands:"
    echo "  init        Provision the strictly-typed .agent/ runtime (non-interactive by default)"
    echo "  add-skill   Add a specific skill from the global library to this project"
    echo "  sync        Synchronize local .agent/ with the kit's upstream"
    echo "  registry    Force-rebuild the lightweight skills.json index"
    echo "  validate    Audit skill manifests for structural integrity"
    echo "  doctor      Check runtime health: SDD, Engram, Context7, MCP (any LLM/IDE)"
    echo "  help        Display this technical guide"
}

add_skill() {
    local SKILL_NAME="$1"
    if [ -z "$SKILL_NAME" ]; then
        echo -e "${YELLOW}Usage: bash scripts/agent add-skill <skill-name>${NC}"
        echo -e "Available skills in global library:"
        find "$KIT_ROOT/skills" -maxdepth 1 -mindepth 1 -type d -exec basename {} \; | sort | column
        return
    fi

    if [ -d "$KIT_ROOT/skills/$SKILL_NAME" ]; then
        echo -e "${BLUE}📦 Adding skill: $SKILL_NAME...${NC}"
        mkdir -p ".agent/skills/$SKILL_NAME"
        cp "$KIT_ROOT/skills/$SKILL_NAME/SKILL.md" ".agent/skills/$SKILL_NAME/"
        bash "$KIT_ROOT/scripts/generate-registry.sh"
        echo -e "${GREEN}✅ Skill $SKILL_NAME successfully added and registry updated.${NC}"
    else
        echo -e "${RED}❌ Skill '$SKILL_NAME' not found in global library.${NC}"
    fi
}

check_doctor() {
    echo -e "${BLUE}🔍 V3 Runtime Health Check${NC}"
    echo -e "${BLUE}   Golden rules: SDD · Engram · Context7 · MCP · Pedrito${NC}\n"

    # 1. Runtime state
    echo -e "${BLUE}[1/5] Runtime...${NC}"
    if [ -d ".agent/state" ]; then
        echo -e "  ✅ Runtime initialized (.agent/state exists)"
        if grep -q "version" .agent/state/env_state.json 2>/dev/null; then
            echo -e "  ✅ env_state.json valid"
        else
            echo -e "  ❌ env_state.json corrupted or missing"
        fi
        if [ -f ".agent/state/allowed_ops.json" ]; then
            echo -e "  ✅ allowed_ops.json present (OP_* tokens resolvable)"
        else
            echo -e "  ⚠️  allowed_ops.json missing — run 'init' to regenerate"
        fi
    else
        echo -e "  ❌ Runtime not initialized. Run: bash scripts/agent init"
    fi

    # 2. SDD check
    echo -e "\n${BLUE}[2/5] SDD (Spec-Driven Development)...${NC}"
    if [ -f ".agent/core/03_development_super_rule.md" ]; then
        echo -e "  ✅ SDD super-rule installed"
    else
        echo -e "  ❌ SDD super-rule missing (.agent/core/03_development_super_rule.md)"
    fi
    if [ -d "specs" ]; then
        SPEC_COUNT=$(find specs -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ✅ specs/ exists ($SPEC_COUNT active spec(s))"
    else
        echo -e "  ⚠️  specs/ not found — non-trivial work cannot be tracked"
    fi

    # 3. Engram check
    echo -e "\n${BLUE}[3/5] Engram (durable memory)...${NC}"
    if [ -f "docs/engram/index.md" ]; then
        ENTRY_COUNT=$(grep -c "^\|" docs/engram/index.md 2>/dev/null || echo 0)
        echo -e "  ✅ Engram index present (~${ENTRY_COUNT} table rows)"
    else
        echo -e "  ❌ docs/engram/index.md missing — Engram is not provisioned"
    fi
    for section in decisions patterns lessons; do
        if [ -d "docs/engram/$section" ]; then
            COUNT=$(find "docs/engram/$section" -name "*.md" ! -name "README.md" 2>/dev/null | wc -l | tr -d ' ')
            echo -e "  ✅ engram/$section: $COUNT entries"
        else
            echo -e "  ⚠️  docs/engram/$section/ missing"
        fi
    done

    # 4. Skill drift check
    echo -e "\n${BLUE}[4/5] Skills & registry drift...${NC}"
    MANIFEST="${KIT_ROOT}/registry/skill_manifest.json"
    RUNTIME_SKILLS=".agent/skills"
    if [ -f "$MANIFEST" ] && [ -d "$RUNTIME_SKILLS" ]; then
        PYTHONIOENCODING=utf-8 python - "$MANIFEST" "$RUNTIME_SKILLS" <<'PY'
import json, sys, os
manifest = json.load(open(sys.argv[1], encoding="utf-8"))
registered = set(manifest['skills'].keys())
runtime = set(os.listdir(sys.argv[2]))
missing = registered - runtime
if missing:
    print(f"  [WARN] Skills registered but missing from runtime: {sorted(missing)}")
else:
    print(f"  [OK] No drift — {len(runtime)} skills in runtime, {len(registered)} registered")
PY
    else
        echo -e "  ⚠️  Cannot check drift (manifest or runtime skills dir missing)"
    fi

    # 5. MCP + Context7 check (generic — any LLM/IDE, any OS)
    echo -e "\n${BLUE}[5/5] MCP & Context7...${NC}"
    MCP_FOUND=false
    CONTEXT7_FOUND=false
    MCP_CANDIDATES=(
        "$HOME/.claude/claude_desktop_config.json"
        "$HOME/.config/Claude/claude_desktop_config.json"
        "$HOME/Library/Application Support/Claude/claude_desktop_config.json"
        "${APPDATA:-}/Claude/claude_desktop_config.json"
        "${LOCALAPPDATA:-}/Claude/claude_desktop_config.json"
        "$HOME/.cursor/mcp.json"
        "${APPDATA:-}/Cursor/User/mcp.json"
        ".cursor/mcp.json"
        "$HOME/.codeium/windsurf/mcp_config.json"
        "$HOME/.gemini/antigravity/mcp_config.json"
        ".vscode/mcp.json"
        "$HOME/.config/Code/User/mcp.json"
        ".mcp.json"
        "mcp.json"
    )

    for path in "${MCP_CANDIDATES[@]}"; do
        if [ -f "$path" ]; then
            echo -e "  ✅ MCP config: $path"
            MCP_FOUND=true
            # Check if context7 is registered inside this config
            if PYTHONIOENCODING=utf-8 python - "$path" <<'PY' 2>/dev/null
import json, sys
try:
    cfg = json.load(open(sys.argv[1], encoding="utf-8"))
    servers = cfg.get("mcpServers", cfg.get("mcp", {}).get("servers", {}))
    found = any("context7" in k.lower() for k in servers)
    sys.exit(0 if found else 1)
except: sys.exit(1)
PY
            then
                echo -e "  ✅ Context7 registered in MCP config"
                CONTEXT7_FOUND=true
            fi
        fi
    done

    if [ "$MCP_FOUND" = "false" ]; then
        echo -e "  ⚠️  No MCP config detected. Kit is LLM/IDE agnostic — configure for your tool:"
        echo -e "       Claude Code : ~/.claude/claude_desktop_config.json"
        echo -e "       Cursor      : ~/.cursor/mcp.json"
        echo -e "       Windsurf    : ~/.codeium/windsurf/mcp_config.json"
        echo -e "       Antigravity : ~/.gemini/antigravity/mcp_config.json"
        echo -e "       Generic     : .mcp.json"
    fi

    if [ "$CONTEXT7_FOUND" = "false" ]; then
        echo -e "  ⚠️  Context7 not found in any MCP config."
        echo -e "       Without Context7, the agent cannot fetch live library docs (hallucination risk)."
        echo -e "       Add it to your MCP config: { \"mcpServers\": { \"context7\": { ... } } }"
    fi

    echo -e "\n${GREEN}Doctor complete. Fix any warnings before starting a SDD cycle.${NC}"
}

case "$COMMAND" in
    "init")
        if [ "${#FORWARD_ARGS[@]}" -eq 0 ]; then
            FORWARD_ARGS=("--non-interactive")
        fi
        bash "$KIT_ROOT/scripts/provision.sh" "${FORWARD_ARGS[@]}"
        bash "$KIT_ROOT/scripts/generate-registry.sh"
        ;;
    "add-skill")
        add_skill "${1:-}"
        ;;
    "sync")
        bash "$KIT_ROOT/scripts/sync-workspace.sh" "${FORWARD_ARGS[@]}"
        ;;
    "registry")
        bash "$KIT_ROOT/scripts/generate-registry.sh"
        ;;
    "validate")
        bash "$KIT_ROOT/scripts/validate-kit.sh"
        ;;
    "doctor")
        check_doctor
        ;;
    "help"|"")
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $COMMAND${NC}"
        show_help
        exit 1
        ;;
esac
