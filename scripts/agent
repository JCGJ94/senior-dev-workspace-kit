#!/bin/bash

# ==============================================================================
# Agent CLI - Unified Workspace Manager (Inspired by Gentle AI)
# ==============================================================================

set -e

KIT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND="${1:-}"
if [ $# -gt 0 ]; then
    shift
fi
FORWARD_ARGS=("$@")

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

show_help() {
    echo -e "${BLUE}"
    echo "       ___  ____"
    echo "      / _ \/  _/"
    echo "     / __ _/ /  "
    echo "    /_/ |_/___/ "
    echo "                "
    echo "   A G E N T   K I T"
    echo -e "${NC}"
    echo -e "${BLUE}🤖 Unified AI Engineering CLI (v3)${NC}"
    echo -e "The bridge between LLM reasoning and professional source code.\n"
    echo -e "Usage: ${GREEN}bash scripts/agent <command>${NC}\n"
    echo "Commands:"
    echo "  init        Provision the strictly-typed .agent/ runtime (non-interactive by default)"
    echo "  add-skill   Add a specific skill from the global library to this project"
    echo "  sync        Synchronize local .agent/ with the kit's upstream"
    echo "  registry    Force-rebuild the lightweight skills.json index"
    echo "  validate    Audit skill manifests for structural integrity"
    echo "  doctor      Check Claude MCP config and runtime health"
    echo "  help        Display this technical guide"
}

add_skill() {
    local SKILL_NAME="$1"
    if [ -z "$SKILL_NAME" ]; then
        echo -e "${YELLOW}Usage: bash scripts/agent add-skill <skill-name>${NC}"
        echo -e "Available skills in global library:"
        find "$KIT_ROOT/skills" -maxdepth 1 -mindepth 1 -type d -exec basename {} \; | sort | column
        return
    fi

    if [ -d "$KIT_ROOT/skills/$SKILL_NAME" ]; then
        echo -e "${BLUE}📦 Adding skill: $SKILL_NAME...${NC}"
        mkdir -p ".agent/skills/$SKILL_NAME"
        cp "$KIT_ROOT/skills/$SKILL_NAME/SKILL.md" ".agent/skills/$SKILL_NAME/"
        bash "$KIT_ROOT/scripts/generate-registry.sh"
        echo -e "${GREEN}✅ Skill $SKILL_NAME successfully added and registry updated.${NC}"
    else
        echo -e "${RED}❌ Skill '$SKILL_NAME' not found in global library.${NC}"
    fi
}

check_doctor() {
    echo -e "${BLUE}🔍 Running Runtime Health Check...${NC}"

    # 1. Runtime state
    if [ -d ".agent/state" ]; then
        echo -e "✅ Runtime initialized (.agent/state exists)"
        if grep -q "version" .agent/state/env_state.json 2>/dev/null; then
            echo -e "✅ env_state.json is valid"
        else
            echo -e "❌ env_state.json is corrupted or missing"
        fi
    else
        echo -e "❌ Runtime not initialized. Run 'init' first."
    fi

    # 2. Skill drift check
    echo -e "\n${BLUE}📦 Checking skill drift...${NC}"
    MANIFEST="${KIT_ROOT}/registry/skill_manifest.json"
    RUNTIME_SKILLS=".agent/skills"
    if [ -f "$MANIFEST" ] && [ -d "$RUNTIME_SKILLS" ]; then
        python - "$MANIFEST" "$RUNTIME_SKILLS" <<'PY'
import json, sys, os
manifest = json.load(open(sys.argv[1]))
registered = set(manifest['skills'].keys())
runtime = set(os.listdir(sys.argv[2]))
missing = (registered & set(os.listdir(os.path.join(sys.argv[2], '..', '..', 'skills')) if os.path.isdir(os.path.join(sys.argv[2], '..', '..', 'skills')) else [])) - runtime
if missing:
    print(f"  ⚠️  Skills registered+source but missing from runtime: {sorted(missing)}")
else:
    print(f"  ✅ No skill drift ({len(runtime)} skills in runtime)")
PY
    fi

    # 3. Claude MCP config check
    echo -e "\n${BLUE}🌍 Checking Claude MCP configuration...${NC}"
    CLAUDE_MCP_LOCATIONS=(
        "$HOME/.claude/claude_desktop_config.json"
        "$HOME/Library/Application Support/Claude/claude_desktop_config.json"
        "$APPDATA/Claude/claude_desktop_config.json"
    )
    MCP_FOUND=false
    for mcp_path in "${CLAUDE_MCP_LOCATIONS[@]}"; do
        if [ -f "$mcp_path" ]; then
            echo -e "✅ Claude MCP config found: $mcp_path"
            MCP_FOUND=true
            break
        fi
    done
    if [ "$MCP_FOUND" = "false" ]; then
        echo -e "⚠️  No Claude MCP config found. Context7 may not be available."
        echo -e "   Expected locations: ~/.claude/claude_desktop_config.json"
    fi

    echo -e "\n${GREEN}Doctor check complete.${NC}"
}

case "$COMMAND" in
    "init")
        if [ "${#FORWARD_ARGS[@]}" -eq 0 ]; then
            FORWARD_ARGS=("--non-interactive")
        fi
        bash "$KIT_ROOT/scripts/provision.sh" "${FORWARD_ARGS[@]}"
        bash "$KIT_ROOT/scripts/generate-registry.sh"
        ;;
    "add-skill")
        add_skill "${1:-}"
        ;;
    "sync")
        bash "$KIT_ROOT/scripts/sync-workspace.sh" "${FORWARD_ARGS[@]}"
        ;;
    "registry")
        bash "$KIT_ROOT/scripts/generate-registry.sh"
        ;;
    "validate")
        bash "$KIT_ROOT/scripts/validate-kit.sh"
        ;;
    "doctor")
        check_doctor
        ;;
    "help"|"")
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $COMMAND${NC}"
        show_help
        exit 1
        ;;
esac
